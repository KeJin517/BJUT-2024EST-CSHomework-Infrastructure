                "${workspaceFolder}\\Homework\\First_Homework_Second_Question.c",
                
                "-I", "${workspaceFolder}\\Core",
                "-I", "${workspaceFolder}\\Task",
                "-I", "${workspaceFolder}\\Homework",
                
                "-o",
                "${workspaceFolder}\\my_program.exe"
